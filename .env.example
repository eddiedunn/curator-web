# Curator Web Frontend Configuration

# API Endpoint
# Default: http://localhost:8950
# Production: Use internal network hostname (e.g., http://curator:8950)
VITE_CURATOR_API_URL=http://localhost:8950

# API Authentication (optional)
# If your Curator API requires an API key, set it here
# VITE_CURATOR_API_KEY=your-api-key-here

# Engram Integration
# URL to Engram web UI for cross-linking
# Default: http://localhost:5173
# Production: https://engram.your-server.example.com
VITE_ENGRAM_WEB_URL=http://localhost:5173

# Feature Flags (optional)
# VITE_ENABLE_DEBUG=false
